{
  "name": "flightdeck",
  "version": "1.2.0",
  "description": "Your personal work-intelligence dashboard",
  "main": "src/main/index.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "demo": "npm run build:renderer && electron . --demo",
    "demo:reseed": "npm run build:renderer && electron . --demo-reseed",
    "screenshots": "npm run build:renderer && node scripts/capture-screenshots.js",
    "test": "node --test test/main-utils.test.js test/main-window-state.test.js test/main-pty-bridge.test.js test/main-ipc-handlers.test.js test/main-ipc-tracker-popout.test.js",
    "dev": "vite src/",
    "build:renderer": "vite build",
    "dist": "npm run build:renderer && electron-builder --win msi",
    "dist:mac": "npm run build:renderer && electron-builder --mac",
    "dist:linux": "npm run build:renderer && electron-builder --linux",
    "dist:all": "npm run build:renderer && electron-builder --win msi --mac --linux",
    "dist:dir": "npm run build:renderer && electron-builder --win dir",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "build": {
    "appId": "com.flightdeck.app",
    "productName": "FlightDeck",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "dist-renderer/**/*"
    ],
    "asarUnpack": [
      "node_modules/@microsoft/workiq/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "msi"
      ]
    },
    "mac": {
      "icon": "src/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "src/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "msi": {
      "perMachine": true,
      "warningsAsErrors": false
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1",
    "svelte": "^5.55.4",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@microsoft/workiq": "^0.4.1",
    "electron-store": "^11.0.2",
    "node-pty": "1.1.0"
  }
}
