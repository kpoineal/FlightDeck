{
  "name": "flightdeck",
  "version": "1.1.0",
  "description": "Your personal work-intelligence dashboard",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "demo": "electron . --demo",
    "test": "node --test test/main-utils.test.js test/main-window-state.test.js test/main-pty-bridge.test.js test/main-ipc-handlers.test.js test/main-ipc-tracker-popout.test.js test/renderer-utils.test.js test/renderer-json-parser.test.js test/renderer-models-tracking.test.js test/renderer-models-radar.test.js test/renderer-models-briefing.test.js test/renderer-day-briefing.test.js test/renderer-tracking-renderers.test.js test/renderer-popout.test.js test/renderer-state.test.js test/renderer-prompts.test.js test/renderer-move-item.test.js test/renderer-delete-scanner.test.js test/renderer-scanner-engine.test.js",
    "dev": "vite src/",
    "build:renderer": "vite build",
    "start:svelte": "npm run build:renderer && electron .",
    "dist": "npm run build:renderer && electron-builder --win msi",
    "dist:mac": "npm run build:renderer && electron-builder --mac",
    "dist:linux": "npm run build:renderer && electron-builder --linux",
    "dist:all": "npm run build:renderer && electron-builder --win msi --mac --linux",
    "dist:dir": "npm run build:renderer && electron-builder --win dir",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "build": {
    "appId": "com.flightdeck.app",
    "productName": "FlightDeck",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "dist-renderer/**/*"
    ],
    "asarUnpack": [
      "node_modules/@microsoft/workiq/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "msi"
      ]
    },
    "mac": {
      "icon": "src/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "src/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "msi": {
      "perMachine": true,
      "warningsAsErrors": false
    }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "svelte": "^5.55.4",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@microsoft/workiq": "^0.4.0",
    "electron-store": "^11.0.2",
    "node-pty": "1.1.0"
  }
}
